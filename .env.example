# ONLYTWINS – set these in Vercel → Project → Settings → Environment Variables. The app runs on Vercel; no local run required. (Optional: copy to .env.local only if you choose to run the app on your machine for development.)

# Required: Supabase (from Supabase project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SITE_URL=https://onlytwins.dev
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Required: Postgres (from Supabase Settings → Database → Connection string, "URI")
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Required for RunPod worker (AI samples + training). Set in Vercel or save in Admin → Leads → Worker.
WORKER_SECRET=your-shared-secret
APP_URL=https://your-app.vercel.app
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
# RunPod dispatch mode: "mock" (no GPU, simulates lifecycle), "cheap" (real GPU, minimal params), "production" (default)
RUNPOD_MODE=production

# Optional: lead scraping (more sources = more leads)
YOUTUBE_API_KEY=
APIFY_TOKEN=

# Optional: cron (Vercel Cron)
CRON_SECRET=

# Optional: image quality filter for leads (Replicate LLaVA)
REPLICATE_API_TOKEN=
FACE_FILTER_ENABLED=false

# Optional: Fal.ai API for face swapping (homepage preview, free tier available)
FAL_API_KEY=

# Optional: admin access (email allowlist only)
ADMIN_OWNER_EMAILS=lush.lure.creative@gmail.com
