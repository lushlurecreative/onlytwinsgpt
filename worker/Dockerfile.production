# GPU-optimized face-swap worker for RunPod
# Based on PyTorch official image with CUDA 12.1 runtime
# Reuses proven Phase 1 face-swap logic

FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

ENV PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System dependencies (use Python 3.10 — the Ubuntu 22.04 default)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-pip \
    build-essential \
    git \
    curl \
    libssl-dev \
    libffi-dev \
    libopenblas-dev \
    liblapack-dev \
    gfortran \
    libhdf5-dev \
    pkg-config \
    libjpeg-dev \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

# Upgrade pip
RUN python -m pip install --upgrade pip setuptools wheel

# Pre-install Cython (required to build insightface from source)
RUN python -m pip install --no-cache-dir cython numpy==1.24.3

# Install GPU-optimized requirements
COPY requirements-gpu.txt .
RUN python -m pip install --no-cache-dir -r requirements-gpu.txt

# Copy ONLY face-swap code (app, face_swap, storage - proven Phase 1 logic)
COPY app.py face_swap.py storage.py .

# Pre-download InsightFace models into the image so startup is instant
# buffalo_l: face detection + recognition (~330MB)
# inswapper_128: face swap ONNX model (~540MB)
RUN python -c "\
from insightface.app import FaceAnalysis; \
app = FaceAnalysis(name='buffalo_l', providers=['CPUExecutionProvider']); \
app.prepare(ctx_id=-1, det_size=(640, 640)); \
print('buffalo_l downloaded OK') \
"
RUN mkdir -p /root/.insightface/models && \
    curl -L -o /root/.insightface/models/inswapper_128.onnx \
    "https://huggingface.co/ezioruan/inswapper_128.onnx/resolve/main/inswapper_128.onnx" && \
    ls -lh /root/.insightface/models/inswapper_128.onnx

# Expose ports for RunPod Load Balancer
EXPOSE 8000 8001

# Health check — models are baked in, so short start-period is fine
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8001/ping || exit 1

# Start HTTP server (RunPod Load Balancer expects this)
CMD ["python", "app.py"]
