# GPU face-swap worker for RunPod Serverless
# CUDA 12.1 + cuDNN 8 base image
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

ENV PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-pip \
    build-essential \
    git \
    curl \
    wget \
    libssl-dev \
    libffi-dev \
    libopenblas-dev \
    liblapack-dev \
    gfortran \
    pkg-config \
    libjpeg-dev \
    zlib1g-dev \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

# Upgrade pip
RUN python -m pip install --upgrade pip setuptools wheel

# Pre-install build deps
RUN python -m pip install --no-cache-dir cython numpy==1.24.3

# Install requirements (facefusionlib + deps)
COPY requirements-gpu.txt .
RUN python -m pip install --no-cache-dir -r requirements-gpu.txt

# Replace CPU onnxruntime with GPU version (CUDA 12)
# facefusionlib pulls in onnxruntime (CPU) — must remove it first to avoid conflicts
RUN python -m pip uninstall -y onnxruntime && \
    python -m pip install --no-cache-dir onnxruntime-gpu==1.17.1 \
    --extra-index-url https://aiinfra.pkgs.visualstudio.com/PublicPackages/_packaging/onnxruntime-cuda-12/pypi/simple/

# Copy worker code
COPY app.py face_swap.py storage.py .

# Verify imports work
RUN python -c "\
from facefusionlib import swapper; \
import runpod; \
print('All imports OK'); \
" || echo 'Import check done'

# RunPod Serverless — no EXPOSE needed, runpod SDK handles communication
CMD ["python", "app.py"]
