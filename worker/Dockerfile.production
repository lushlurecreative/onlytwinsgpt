# GPU-optimized face-swap worker for RunPod
# CUDA 12.1 + cuDNN 8 base image
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

ENV PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System dependencies — includes wget/unzip for model downloads, libgl1/libglib for opencv
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-pip \
    build-essential \
    git \
    curl \
    wget \
    unzip \
    libssl-dev \
    libffi-dev \
    libopenblas-dev \
    liblapack-dev \
    gfortran \
    libhdf5-dev \
    pkg-config \
    libjpeg-dev \
    zlib1g-dev \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

# Upgrade pip
RUN python -m pip install --upgrade pip setuptools wheel

# Pre-install Cython (required to build insightface from source)
RUN python -m pip install --no-cache-dir cython numpy==1.24.3

# Install requirements (everything except onnxruntime-gpu)
COPY requirements-gpu.txt .
RUN python -m pip install --no-cache-dir -r requirements-gpu.txt

# Install onnxruntime-gpu from CUDA 12 index (PyPI default is CUDA 11.8)
RUN python -m pip install --no-cache-dir onnxruntime-gpu==1.17.1 \
    --extra-index-url https://aiinfra.pkgs.visualstudio.com/PublicPackages/_packaging/onnxruntime-cuda-12/pypi/simple/

# Pre-download buffalo_l model (~330MB) via direct URL
RUN mkdir -p /root/.insightface/models/buffalo_l && \
    wget -q -O /tmp/buffalo_l.zip https://github.com/deepinsight/insightface/releases/download/v0.7/buffalo_l.zip && \
    unzip -o /tmp/buffalo_l.zip -d /root/.insightface/models/buffalo_l && \
    rm /tmp/buffalo_l.zip && \
    ls -la /root/.insightface/models/buffalo_l/

# Pre-download inswapper_128 model (~554MB)
RUN wget -q -O /root/.insightface/models/inswapper_128.onnx \
    "https://huggingface.co/ezioruan/inswapper_128.onnx/resolve/main/inswapper_128.onnx" && \
    ls -lh /root/.insightface/models/inswapper_128.onnx

# Copy worker code
COPY app.py face_swap.py storage.py .

# Expose ports for RunPod Load Balancer
EXPOSE 8000 8001

# Health check — models are baked in, short start-period
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8001/ping || exit 1

# Start HTTP server
CMD ["python", "app.py"]
