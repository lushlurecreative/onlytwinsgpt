# GPU-optimized face-swap worker for RunPod
# Based on PyTorch official image with CUDA 12.1 runtime
# Reuses proven Phase 1 face-swap logic

FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

ENV PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-dev \
    python3-pip \
    build-essential \
    git \
    curl \
    libssl-dev \
    libffi-dev \
    libopenblas-dev \
    liblapack-dev \
    gfortran \
    libhdf5-dev \
    pkg-config \
    libjpeg-dev \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

# Make python3.11 the default and fix pip to use it
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# Upgrade pip (use python -m pip to guarantee correct Python)
RUN python -m pip install --upgrade pip setuptools wheel

# Pre-install Cython (required to build insightface from source)
RUN python -m pip install --no-cache-dir cython numpy==1.24.3

# Install GPU-optimized requirements
COPY requirements-gpu.txt .
RUN python -m pip install --no-cache-dir -r requirements-gpu.txt

# Copy ONLY face-swap code (app, face_swap, storage - proven Phase 1 logic)
COPY app.py face_swap.py storage.py .

# Expose ports for RunPod Load Balancer
EXPOSE 8000 8001

# Health check endpoint (curl-based, more reliable than import requests)
# Note: start-period=120s accounts for InsightFace model download on first run (~30-60s)
HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:8001/ping || exit 1

# Start HTTP server (RunPod Load Balancer expects this)
CMD ["python", "app.py"]
