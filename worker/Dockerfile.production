# GPU face-swap worker for RunPod Serverless
# CUDA 12.1 + cuDNN 8 base image
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

ENV PYTHONUNBUFFERED=1 \
    DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System dependencies (including unzip for model packs)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-pip \
    build-essential \
    git \
    curl \
    wget \
    unzip \
    libssl-dev \
    libffi-dev \
    libopenblas-dev \
    liblapack-dev \
    gfortran \
    pkg-config \
    libjpeg-dev \
    zlib1g-dev \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

# Upgrade pip
RUN python -m pip install --upgrade pip setuptools wheel

# Pre-install build deps
RUN python -m pip install --no-cache-dir cython numpy==1.24.3

# Install requirements (facefusionlib + deps)
COPY requirements-gpu.txt .
RUN python -m pip install --no-cache-dir -r requirements-gpu.txt

# Replace CPU onnxruntime with GPU version (CUDA 12)
RUN python -m pip uninstall -y onnxruntime && \
    python -m pip install --no-cache-dir onnxruntime-gpu==1.17.1 \
    --extra-index-url https://aiinfra.pkgs.visualstudio.com/PublicPackages/_packaging/onnxruntime-cuda-12/pypi/simple/

# Training path: FLUX LoRA via diffusers + peft. Installed AFTER face-swap deps
# so the face-swap pipeline still builds even if training pulls evolve.
# Torch is CUDA 12.1 wheel (matches cuDNN base image).
RUN python -m pip install --no-cache-dir \
    torch==2.2.0 torchvision==0.17.0 --index-url https://download.pytorch.org/whl/cu121
# diffusers is pinned to 0.30.3: FluxPipeline first shipped in 0.30.0 and
# 0.30.x does NOT require torch.xpu (added in diffusers 0.36.0 / torch 2.4+).
# peft 0.12.0 is the last release compatible with diffusers 0.30.x.
RUN python -m pip install --no-cache-dir \
    "diffusers==0.30.3" \
    "transformers==4.44.2" \
    "accelerate==0.33.0" \
    "peft==0.12.0" \
    "safetensors==0.4.5" \
    sentencepiece \
    "supabase>=2.0.0"

# Download FaceFusion ONNX models (from facefusion-assets, NOT InsightFace buffalo_l)
# facefusionlib expects these at ../.assets/models/ relative to the package
# Models list derived from facefusionlib 1.1.3 source: face_analyser, face_masker, face_swapper, face_enhancer
ENV MODELS_DIR="/usr/local/lib/python3.10/dist-packages/.assets/models"
ENV MODELS_URL="https://github.com/facefusion/facefusion-assets/releases/download/models-3.0.0"
# 3 models (gender_age, face_occluder, face_parser) were removed from facefusion-assets GitHub releases.
# Sourced from HuggingFace mirror instead: huggingface.co/JackCui/facefusion
ENV MODELS_HF="https://huggingface.co/JackCui/facefusion/resolve/main"
RUN mkdir -p "$MODELS_DIR"
RUN curl -fSL -o "$MODELS_DIR/yoloface_8n.onnx"       "$MODELS_URL/yoloface_8n.onnx"
RUN curl -fSL -o "$MODELS_DIR/arcface_w600k_r50.onnx"  "$MODELS_URL/arcface_w600k_r50.onnx"
RUN curl -fSL -o "$MODELS_DIR/gender_age.onnx"          "$MODELS_HF/gender_age.onnx"
RUN curl -fSL -o "$MODELS_DIR/2dfan4.onnx"              "$MODELS_URL/2dfan4.onnx"
RUN curl -fSL -o "$MODELS_DIR/inswapper_128.onnx"       "$MODELS_URL/inswapper_128.onnx"
# HyperSwap 1c 256 — primary swap model (256x256, embedding-based, FaceFusion Labs 2025)
ENV MODELS_HF_33="https://huggingface.co/facefusion/models-3.3.0/resolve/main"
RUN curl -fSL -o "$MODELS_DIR/hyperswap_1c_256.onnx"   "$MODELS_HF_33/hyperswap_1c_256.onnx"
RUN curl -fSL -o "$MODELS_DIR/gfpgan_1.4.onnx"          "$MODELS_URL/gfpgan_1.4.onnx"
RUN curl -fSL -o "$MODELS_DIR/face_occluder.onnx"       "$MODELS_HF/face_occluder.onnx"
RUN curl -fSL -o "$MODELS_DIR/face_parser.onnx"          "$MODELS_HF/face_parser.onnx"
RUN echo "=== All models downloaded ===" && ls -la "$MODELS_DIR/"

# Copy worker code
COPY app.py face_swap.py storage.py train_lora.py .

# Verify imports and models (face-swap path + training path)
RUN python -c "\
import os; \
models_dir = '/usr/local/lib/python3.10/dist-packages/.assets/models'; \
files = os.listdir(models_dir); \
print(f'Models in {models_dir}: {files}'); \
required = ['yoloface_8n.onnx', 'arcface_w600k_r50.onnx', 'gender_age.onnx', '2dfan4.onnx', 'inswapper_128.onnx', 'gfpgan_1.4.onnx', 'face_occluder.onnx', 'face_parser.onnx']; \
missing = [m for m in required if m not in files]; \
assert not missing, f'Missing models: {missing}'; \
import runpod; \
import torch; \
import diffusers; \
import peft; \
import safetensors; \
print(f'torch={torch.__version__} diffusers={diffusers.__version__} peft={peft.__version__}'); \
print('All imports and models OK'); \
"

# RunPod Serverless — no EXPOSE needed
CMD ["python", "app.py"]
