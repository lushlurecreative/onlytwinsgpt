# RunPod Load Balancer: HTTP server via app.py
# Uses runpod/base which has Python, pip, and GPU support pre-configured

FROM runpod/base:0.4.2-cuda12.1.1

ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Install system dependencies for insightface and face-swap
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy and install Python requirements
COPY requirements.txt requirements-full.txt ./
RUN pip install --no-cache-dir -r requirements-full.txt

# Copy application files
COPY storage.py train_lora.py generate_flux.py main.py watermark.py face_swap.py app.py ./

# Health check on separate port (8001)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python3 -c "import requests; requests.get('http://localhost:8001/ping', timeout=5)"

# Load Balancer: HTTP server for face-swap
CMD ["python3", "app.py"]
